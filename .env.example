# Copy to Railway → Service → Variables (or use Railway CLI)

# Required in production
SECRET_KEY=generate-a-long-random-string-here
DEBUG=False

# Optional — Railway sets RAILWAY_PUBLIC_DOMAIN automatically when you generate a domain
# ALLOWED_HOSTS=your-custom-domain.com
# CSRF_TRUSTED_ORIGINS=https://your-custom-domain.com

# PostgreSQL — added automatically when you link a Railway Postgres plugin
# DATABASE_URL=postgresql://...
